{
  "name": "newdom",
  "version": "0.1.0",
  "private": true,
  "description": "NewDOM — GPU compute UI substrate (Phase 0)",
  "scripts": {
    "build":   "bash scripts/build-wasm.sh",
    "dev":     "npm run build && npm run serve",
    "serve":   "serve examples/web-demo --listen 3000",
    "check":   "cargo check -p newdom-core -p newdom-wasm --target wasm32-unknown-unknown",
    "clean":   "cargo clean && rimraf examples/web-demo/pkg"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "serve":  "^14.2.4"
  }
}
